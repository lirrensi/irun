# Normalize line endings so gofmt stays happy on every runner.
# Source files: LF. Windows shell scripts: CRLF. Everything else: let git decide.

*               text=auto eol=lf

*.go            text eol=lf
*.mod           text eol=lf
*.sum           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.json          text eol=lf
*.toml          text eol=lf
*.md            text eol=lf
*.txt           text eol=lf

*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Binary files: do not touch.
*.exe           binary
*.png           binary
*.jpg           binary
*.gif           binary
*.ico           binary
